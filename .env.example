DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=America/Santiago

# --- Producción (Render) ---
# Postgres administrado por Render. Render lo inyecta solo si conectás la
# base de datos al Web Service; si no, copiá la "Internal Database URL".
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudinary: pegar tal cual el valor "API Environment variable" del
# dashboard de Cloudinary (Account Details).
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Dominios adicionales aceptados además de localhost (separados por coma).
# RENDER_EXTERNAL_HOSTNAME se inyecta automáticamente en Render, no hace falta setearla a mano.
# ALLOWED_HOSTS=miapp.onrender.com
# CSRF_TRUSTED_ORIGINS=https://miapp.onrender.com
